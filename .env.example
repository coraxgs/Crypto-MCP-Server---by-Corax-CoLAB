# ==========================================
# Crypto MCP Server - Environment Variables
# ==========================================

# ------------------------------------------
# General Dashboard / Backend Settings
# ------------------------------------------
# The port the backend server runs on
PORT=4000

# Password to authenticate critical operations from the dashboard (Required for trading, reasoning, etc.)
DASHBOARD_PASSWORD=your_secure_password_here

# Timeout for MCP server requests (in milliseconds)
MCP_TIMEOUT=8000

# ------------------------------------------
# MCP Endpoints (Local tool connections)
# ------------------------------------------
MCP_CCXT=http://127.0.0.1:7001/mcp
MCP_FREQTRADE=http://127.0.0.1:7002/mcp
MCP_OCTOBOT=http://127.0.0.1:7003/mcp
MCP_PORTFOLIO=http://127.0.0.1:7004/mcp
MCP_TA=http://127.0.0.1:7005/mcp
MCP_SUPERALGOS=http://127.0.0.1:7006/mcp
MCP_ONCHAIN=http://127.0.0.1:7007/mcp
MCP_COINGECKO=http://127.0.0.1:7010/mcp
MCP_HUMMINGBOT=http://127.0.0.1:7014/mcp
MCP_LLM=http://127.0.0.1:7015/mcp
MCP_NOTIFIER=http://127.0.0.1:7016/mcp
MCP_NEWS=http://127.0.0.1:7017/mcp

# Dashboard API URL to communicate back with the frontend backend for human-in-the-loop approvals
DASHBOARD_API_URL=http://backend:4000

# ------------------------------------------
# CCXT & Trading Protections (Strict Mode)
# ------------------------------------------
# Maximum trade amount in USD
MAX_TRADE_USD=100.0

# Comma-separated list of allowed trading pairs. If empty, all trading is blocked (Fail-closed)
ALLOWED_PAIRS=BTC/USDT,SOL/USDT

# ------------------------------------------
# Exchange API Keys
# Replace {EXCHANGE} with uppercase exchange names (e.g. BINANCE, KRAKEN, COINBASE)
# ------------------------------------------
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_SECRET=your_kraken_api_secret

# ------------------------------------------
# Portfolio Caching Settings
# ------------------------------------------
# Cache time-to-live for portfolio balances in seconds
PORTFOLIO_CACHE_TTL=30
# Mapping time-to-live in seconds
PORTFOLIO_MAPPING_TTL=3600

# ------------------------------------------
# On-Chain / Web3 Settings
# ------------------------------------------
ETH_RPC_URL=https://eth.llamarpc.com
ETH_PRIVATE_KEY=your_eth_private_key
ETH_PUBLIC_ADDRESS=your_eth_public_address

# ------------------------------------------
# External Integrations (Bots)
# ------------------------------------------
FREQTRADE_REST_URL=http://127.0.0.1:8080
FREQTRADE_API_KEY=

OCTOBOT_REST_URL=http://127.0.0.1:5001
OCTOBOT_API_KEY=

SUPERALGOS_REST_URL=http://127.0.0.1:34248

HUMMINGBOT_REST_URL=https://127.0.0.1:15888

# ------------------------------------------
# Notifier MCP (Alerts)
# ------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# ------------------------------------------
# LLM Settings (AI Copilot)
# ------------------------------------------
LLM_MODEL=ollama/mistral
LLM_API_BASE=http://127.0.0.1:11434
LLM_API_KEY=your_llm_api_key
